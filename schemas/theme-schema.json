{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hogbaysoftware.com/schemas/bike-theme.json",
  "title": "Bike Outliner Theme",
  "description": "JSON schema for Bike Outliner theme files",
  "type": "object",
  "required": [],
  "properties": {
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the theme. The theme's display name is derived from the filename (split on '-', each word capitalized), similar to how extension names are derived.",
      "properties": {
        "version": {
          "type": "string",
          "description": "Theme version"
        },
        "author": {
          "type": "string",
          "description": "Theme author"
        },
        "appearance": {
          "type": "string",
          "enum": ["light", "dark", "any"],
          "description": "Preferred appearance mode. 'light' for light mode only, 'dark' for dark mode only, 'any' or omit for both."
        }
      }
    },
    "colors": {
      "type": "object",
      "description": "Color definitions used throughout the theme. Predefined properties are semantic colors used by Bike. Additional custom colors can also be defined. Colors can be referenced elsewhere using $name syntax.",
      "properties": {
        "text": {
          "$ref": "#/$defs/color",
          "description": "Base text color",
          "default": "text"
        },
        "accent": {
          "$ref": "#/$defs/color",
          "description": "Accent color for highlights and interactive elements",
          "default": "accent"
        },
        "background": {
          "$ref": "#/$defs/color",
          "description": "Semantic background color used for contrast and blending calculations. To change the editor's visual background, use materials.editor instead.",
          "default": "textBackground"
        },
        "caret": {
          "$ref": "#/$defs/color",
          "description": "Text insertion caret color"
        },
        "caretLine": {
          "$ref": "#/$defs/color",
          "description": "Background highlight for the line containing the caret"
        },
        "caretMessage": {
          "$ref": "#/$defs/color",
          "description": "Text color of caret messages (e.g. Task List)"
        },
        "textBackgroundSelected": {
          "$ref": "#/$defs/color",
          "description": "Text selection highlight color"
        },
        "blockBackgroundSelected": {
          "$ref": "#/$defs/color",
          "description": "Block selection highlight color"
        },
        "findMatch": {
          "$ref": "#/$defs/color",
          "description": "Find/search match highlight color"
        },
        "findMatchCurrent": {
          "$ref": "#/$defs/color",
          "description": "Current find/search match highlight color"
        },
        "handle": {
          "$ref": "#/$defs/color",
          "description": "Row handle (disclosure triangle) color"
        },
        "handleUnloaded": {
          "$ref": "#/$defs/color",
          "description": "Row handle color when row has no children or is expanded"
        },
        "guideLine": {
          "$ref": "#/$defs/color",
          "description": "Indentation guide line color"
        },
        "focusArrow": {
          "$ref": "#/$defs/color",
          "description": "Focus arrow indicator color"
        },
        "grammar": {
          "$ref": "#/$defs/color",
          "description": "Grammar check underline color"
        },
        "spelling": {
          "$ref": "#/$defs/color",
          "description": "Spelling check underline color"
        },
        "replacement": {
          "$ref": "#/$defs/color",
          "description": "Text replacement indicator color"
        },
        "titlebarSeparator": {
          "$ref": "#/$defs/color",
          "description": "Separator below the titlebar"
        },
        "sidebarSeparators": {
          "$ref": "#/$defs/color",
          "description": "Split view dividers between sidebar, editor, and inspector"
        },
        "editorBarSeparators": {
          "$ref": "#/$defs/color",
          "description": "Toolbar separator (top) and bottom panel separators (status bar, find, check)"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/color"
      }
    },
    "materials": {
      "type": "object",
      "description": "Material definitions used throughout the theme",
      "properties": {
        "window": {
          "$ref": "#/$defs/material"
        },
        "titlebar": {
          "$ref": "#/$defs/material"
        },
        "sidebar": {
          "$ref": "#/$defs/material"
        },
        "editor": {
          "$ref": "#/$defs/material"
        },
        "editorBars": {
          "$ref": "#/$defs/material"
        },
        "inspector": {
          "$ref": "#/$defs/material"
        }
      },
      "additionalProperties": false
    },
    "rows": {
      "type": "object",
      "description": "Styling for different row types.",
      "properties": {
        "body": { "$ref": "#/$defs/textStyle", "description": "Default body text style" },
        "heading": { "$ref": "#/$defs/textStyle", "description": "Heading row style" },
        "note": { "$ref": "#/$defs/textStyle", "description": "Note row style" },
        "blockquote": { "$ref": "#/$defs/textStyle", "description": "Blockquote row style" },
        "codeblock": { "$ref": "#/$defs/textStyle", "description": "Code block row style" },
        "task": { "$ref": "#/$defs/textStyle", "description": "Task list row style" },
        "orderedList": { "$ref": "#/$defs/textStyle", "description": "Ordered list row style" },
        "unorderedList": { "$ref": "#/$defs/textStyle", "description": "Unordered list row style" },
        "horizontalRule": {
          "$ref": "#/$defs/textStyle",
          "description": "Horizontal rule row style"
        }
      },
      "additionalProperties": false
    },
    "runs": {
      "type": "object",
      "description": "Styling for text runs and inline formatting.",
      "properties": {
        "strong": { "$ref": "#/$defs/textStyle", "description": "Bold/strong text style" },
        "emphasis": { "$ref": "#/$defs/textStyle", "description": "Italic/emphasized text style" },
        "strikethrough": { "$ref": "#/$defs/textStyle", "description": "Strikethrough text style" },
        "code": { "$ref": "#/$defs/textStyle", "description": "Inline code style" },
        "mark": {
          "$ref": "#/$defs/textStyle",
          "description": "Marked/highlighted text style"
        },
        "link": { "$ref": "#/$defs/textStyle", "description": "Link text style" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "color": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^\\$[a-zA-Z0-9_-][a-zA-Z0-9_-]*$",
          "description": "Reference to a color defined in colors ($text or $my-custom-color)"
        },
        {
          "type": "string",
          "pattern": "^#([0-9a-fA-F]{3}|[0-9a-fA-F]{4}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})$",
          "description": "Hex color code (#RGB, #RGBA, #RRGGBB, or #RRGGBBAA)"
        },
        {
          "type": "string",
          "pattern": "^rgba?\\(.*\\)$",
          "description": "RGB/RGBA color function (rgb(255, 0, 0), rgba(255 0 0 / 50%), rgb(100% 0% 0%))"
        },
        {
          "type": "string",
          "pattern": "^hsla?\\(.*\\)$",
          "description": "HSL/HSLA color function (hsl(120, 100%, 50%), hsla(120deg 100% 50% / 0.5))"
        },
        {
          "type": "string",
          "pattern": "^oklab\\(.*\\)$",
          "description": "OKLab perceptually uniform color (oklab(0.5 0.1 -0.1), oklab(50% 0.1 -0.1 / 80%))"
        },
        {
          "type": "string",
          "pattern": "^oklch\\(.*\\)$",
          "description": "OKLCH cylindrical color (oklch(0.7 0.15 180), oklch(70% 0.15 180deg / 50%))"
        },
        {
          "type": "string",
          "pattern": "^color-mix\\(.*\\)$",
          "description": "Mix two colors (color-mix(in oklch, red, blue), color-mix(in srgb, $primary 30%, white))"
        },
        {
          "type": "string",
          "pattern": "^color-contrast\\(.*\\)$",
          "description": "Select highest contrast color (color-contrast($background vs black, white), color-contrast(gray vs black, white to AA))"
        },
        {
          "type": "string",
          "description": "macOS named colors, these adapt to light/dark mode",
          "enum": [
            "text",
            "textHeader",
            "textBackground",
            "textBackgroundSelected",

            "contentBackgroundSelected",
            "contentBackgroundSelectedUnemphasized",
            "windowBackground",

            "label",
            "labelSecondary",
            "labelTertiary",
            "labelQuaternary",
            "labelQuinary",

            "link",
            "accent",
            "shadow",
            "separator",
            "highlight",
            "findHighlight",

            "systemBlue",
            "systemBrown",
            "systemCyan",
            "systemGray",
            "systemGreen",
            "systemIndigo",
            "systemMint",
            "systemOrange",
            "systemPink",
            "systemPurple",
            "systemRed",
            "systemTeal",
            "systemYellow"
          ]
        },
        {
          "type": "string",
          "description": "CSS named colors, these are standard color names recognized by most browsers",
          "enum": [
            "red",
            "green",
            "blue",
            "black",
            "white",
            "gray",
            "grey",

            "yellow",
            "orange",
            "purple",
            "pink",
            "brown",
            "cyan",
            "magenta",
            "indigo",
            "mint",
            "teal",

            "clear",
            "transparent",

            "aliceblue",
            "antiquewhite",
            "aqua",
            "aquamarine",
            "azure",
            "beige",
            "bisque",
            "blanchedalmond",
            "blueviolet",
            "burlywood",
            "cadetblue",
            "chartreuse",
            "chocolate",
            "coral",
            "cornflowerblue",
            "cornsilk",
            "crimson",
            "darkblue",
            "darkcyan",
            "darkgoldenrod",
            "darkgray",
            "darkgrey",
            "darkgreen",
            "darkkhaki",
            "darkmagenta",
            "darkolivegreen",
            "darkorange",
            "darkorchid",
            "darkred",
            "darksalmon",
            "darkseagreen",
            "darkslateblue",
            "darkslategray",
            "darkslategrey",
            "darkturquoise",
            "darkviolet",
            "deeppink",
            "deepskyblue",
            "dimgray",
            "dimgrey",
            "dodgerblue",
            "firebrick",
            "floralwhite",
            "forestgreen",
            "fuchsia",
            "gainsboro",
            "ghostwhite",
            "gold",
            "goldenrod",
            "greenyellow",
            "honeydew",
            "hotpink",
            "indianred",
            "ivory",
            "khaki",
            "lavender",
            "lavenderblush",
            "lawngreen",
            "lemonchiffon",
            "lightblue",
            "lightcoral",
            "lightcyan",
            "lightgoldenrodyellow",
            "lightgray",
            "lightgrey",
            "lightgreen",
            "lightpink",
            "lightsalmon",
            "lightseagreen",
            "lightskyblue",
            "lightslategray",
            "lightslategrey",
            "lightsteelblue",
            "lightyellow",
            "lime",
            "limegreen",
            "linen",
            "maroon",
            "mediumaquamarine",
            "mediumblue",
            "mediumorchid",
            "mediumpurple",
            "mediumseagreen",
            "mediumslateblue",
            "mediumspringgreen",
            "mediumturquoise",
            "mediumvioletred",
            "midnightblue",
            "mintcream",
            "mistyrose",
            "moccasin",
            "navajowhite",
            "navy",
            "oldlace",
            "olive",
            "olivedrab",
            "orangered",
            "orchid",
            "palegoldenrod",
            "palegreen",
            "paleturquoise",
            "palevioletred",
            "papayawhip",
            "peachpuff",
            "peru",
            "plum",
            "powderblue",
            "rosybrown",
            "royalblue",
            "saddlebrown",
            "salmon",
            "sandybrown",
            "seagreen",
            "seashell",
            "sienna",
            "silver",
            "skyblue",
            "slateblue",
            "slategray",
            "slategrey",
            "snow",
            "springgreen",
            "steelblue",
            "tan",
            "thistle",
            "tomato",
            "turquoise",
            "violet",
            "wheat",
            "whitesmoke",
            "yellowgreen"
          ]
        }
      ]
    },
    "gradient": {
      "type": "object",
      "description": "Gradient definition with color stops",
      "required": ["type", "stops"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["linear", "radial"],
          "description": "Type of gradient"
        },
        "stops": {
          "type": "array",
          "description": "Color stops for the gradient",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["color", "position"],
            "properties": {
              "color": {
                "$ref": "#/$defs/color"
              },
              "position": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Position of the color stop (0.0 to 1.0)"
              }
            },
            "additionalProperties": false
          }
        },
        "angle": {
          "type": "number",
          "minimum": 0,
          "maximum": 360,
          "description": "Angle in degrees for linear gradients (0 = top to bottom, 90 = left to right)"
        },
        "centerX": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Horizontal center position for radial gradients (0.0 to 1.0)"
        },
        "centerY": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Vertical center position for radial gradients (0.0 to 1.0)"
        }
      },
      "additionalProperties": false
    },
    "material": {
      "oneOf": [
        {
          "$ref": "#/$defs/color"
        },
        {
          "$ref": "#/$defs/gradient"
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "const": "glass",
              "description": "Specifies this is a glass material"
            },
            "style": {
              "type": "string",
              "enum": ["clear", "regular"],
              "default": "regular",
              "description": "Style of the glass material"
            },
            "tintColor": {
              "$ref": "#/$defs/color",
              "default": null,
              "description": "Tint color for the glass material"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "const": "system",
              "description": "Specifies this is a system material"
            },
            "style": {
              "type": "string",
              "enum": ["header", "titlebar", "windowBackground"],
              "default": "header",
              "description": "Style of the system material"
            },
            "opacity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": null,
              "description": "Opacity of the material, null for default"
            },
            "followsActive": {
              "type": "boolean",
              "default": false,
              "description": "Appearance changes based on window active state"
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "A visual material (color, gradient, glass, or system)"
    },
    "textStyle": {
      "type": "object",
      "description": "Styling properties for rows and runs. All properties are optional.",
      "properties": {
        "color": {
          "$ref": "#/$defs/color",
          "description": "Text color. Supports color references ($name), hex codes, CSS functions, and named colors."
        },
        "backgroundColor": {
          "$ref": "#/$defs/color",
          "description": "Background color behind text."
        },
        "fontFamily": {
          "type": "string",
          "description": "Font family name (e.g., 'SF Mono', 'Helvetica')"
        },
        "fontAdjust": {
          "type": "number",
          "description": "Font size multiplier relative to base font size (e.g., 1.2 = 20% larger, 0.8 = 20% smaller)"
        },
        "fontWeight": {
          "type": "string",
          "enum": [
            "ultraLight",
            "thin",
            "light",
            "regular",
            "medium",
            "semibold",
            "bold",
            "heavy",
            "black"
          ],
          "description": "Font weight"
        },
        "fontTraits": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["italic", "bold", "expanded", "condensed", "monospace"]
          },
          "description": "Font traits to apply (italic, bold, expanded, condensed, monospace)"
        },
        "underline": {
          "$ref": "#/$defs/textLineStyle",
          "description": "Underline styling"
        },
        "strikethrough": {
          "$ref": "#/$defs/textLineStyle",
          "description": "Strikethrough styling"
        }
      },
      "additionalProperties": false
    },
    "textLineStyle": {
      "type": "object",
      "description": "Styling properties for underline and strikethrough lines.",
      "properties": {
        "color": {
          "$ref": "#/$defs/color",
          "description": "Line color. Supports color references ($name), hex codes, CSS functions, and named colors."
        },
        "single": {
          "type": "boolean",
          "description": "Single line style"
        },
        "thick": {
          "type": "boolean",
          "description": "Thick line style"
        },
        "double": {
          "type": "boolean",
          "description": "Double line style"
        },
        "patternDot": {
          "type": "boolean",
          "description": "Dot pattern"
        },
        "patternDash": {
          "type": "boolean",
          "description": "Dash pattern"
        },
        "patternDashDot": {
          "type": "boolean",
          "description": "Dash-dot pattern"
        },
        "patternDashDotDot": {
          "type": "boolean",
          "description": "Dash-dot-dot pattern"
        },
        "byWord": {
          "type": "boolean",
          "description": "Apply style word by word"
        }
      },
      "additionalProperties": false
    }
  }
}
