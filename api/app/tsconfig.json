{
  "compilerOptions": {
    "lib": ["ESNext"],
    "strict": true,
    "strictNullChecks": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitThis": true,
    "noFallthroughCasesInSwitch": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "bike/app": ["./index.d.ts"],
      "bike/core": ["../core/json.d.ts"]
    }
  }
}
